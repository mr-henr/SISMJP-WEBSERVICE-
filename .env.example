# ── Certificado Digital ICP-Brasil A1 (DO CONTADOR) ────────────────────────
# Um único certificado A1 do contador com procuração eletrônica das empresas.
# Caminhos RELATIVOS são resolvidos a partir da pasta sismjp-webservice/.
# Caminhos ABSOLUTOS funcionam normalmente quando necessário.
#
# Exemplo relativo:  CERT_PATH=certs/contador.pfx
# Exemplo absoluto:  CERT_PATH=C:/certificados/contador.pfx
CERT_PATH=certs/contador.pfx
CERT_PASSWORD=senha_do_certificado

# ── Ambiente ────────────────────────────────────────────────────────────────
# "true" para homologação, "false" (ou vazio) para produção
USE_HOMOLOG=false

# ── Planilha de empresas ─────────────────────────────────────────────────────
# Relativo a sismjp-webservice/ (padrão: services/Auto_Prefeitura.xlsx)
# SPREADSHEET_PATH=services/Auto_Prefeitura.xlsx

# ── Pasta de saída ───────────────────────────────────────────────────────────
# Pasta raiz onde serão criadas Prestador/, Tomador/, Consulta Retroativa/
# Relativo a sismjp-webservice/ (padrão: output/)
# Para usar pasta de rede ou drive mapeado, use caminho absoluto:
# OUTPUT_BASE_PATH=Z:/Contattus/Automacao/Prefeitura
OUTPUT_BASE_PATH=output

# ── SIEG ────────────────────────────────────────────────────────────────────
SIEG_API_KEY=sua_chave_sieg_aqui

# ── NIBO ────────────────────────────────────────────────────────────────────
NIBO_API_KEY=sua_chave_nibo_aqui
NIBO_ACCOUNTING_FIRM_ID=id_da_firma_contabil
NIBO_USER_ID=seu_user_id_nibo
