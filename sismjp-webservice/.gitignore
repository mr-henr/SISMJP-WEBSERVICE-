# ── Ambiente e segredos ──────────────────────────────────────────────────────
.env
*.env

# ── Certificados digitais (NUNCA commitar) ───────────────────────────────────
# A pasta certs/ é rastreada para manter a estrutura, mas os arquivos não.
certs/*
!certs/.gitkeep
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer

# ── Saída gerada pela automação ──────────────────────────────────────────────
output/
*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
