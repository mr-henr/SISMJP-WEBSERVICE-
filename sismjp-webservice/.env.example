# ── Certificado Digital ICP-Brasil A1 ──────────────────────────────────────
# Caminho absoluto para o arquivo .pfx / .p12
CERT_PATH=C:/certs/empresa.pfx
# Senha do certificado
CERT_PASSWORD=senha_do_certificado

# ── Ambiente ────────────────────────────────────────────────────────────────
# "true" para homologação, "false" (ou vazio) para produção
USE_HOMOLOG=false

# ── Saída ───────────────────────────────────────────────────────────────────
# Pasta raiz onde serão criadas as subpastas Prestador/, Tomador/, etc.
OUTPUT_BASE_PATH=C:/Drive Contattus/Automacao/Prefeitura

# ── SIEG ────────────────────────────────────────────────────────────────────
SIEG_API_KEY=sua_chave_sieg_aqui

# ── NIBO ────────────────────────────────────────────────────────────────────
NIBO_API_KEY=sua_chave_nibo_aqui
NIBO_ACCOUNTING_FIRM_ID=id_da_firma_contabil
NIBO_USER_ID=seu_user_id_nibo
