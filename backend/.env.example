# ============================================================
# NFS-e JP Manager - Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Ambiente de execução: homologacao | producao
AMBIENTE=homologacao

# Chave Fernet para criptografia das senhas dos certificados no banco.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NUNCA commite a chave real no git!
SECRET_KEY=SUBSTITUA-POR-UMA-CHAVE-FERNET-REAL

# URL do banco de dados SQLite
DATABASE_URL=sqlite:///./nfse.db

# Origens CORS permitidas (separe por vírgula)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# URLs dos WebServices (não altere a menos que a prefeitura mude os endpoints)
WSDL_HOMOLOGACAO=https://ws-homologacao-rtc.giss.com.br/service-ws/nf/nfse-ws
WSDL_PRODUCAO=https://ws-joaopessoa.giss.com.br/service-ws/nf/nfse-ws
